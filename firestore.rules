rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // In this hybrid environment, the client utilizes a custom local/mock authentication (with a list of allowed enterprise users).
    // The production Firebase Auth instance remains unauthenticated on the client. 
    // Therefore, security rules are customized to allow unauthenticated reads and writes for these specific collections to match user intent.

    function isSignedIn() {
      return true; 
    }

    function isOwner(userId) {
      return true; 
    }

    function isAdmin() {
      return true; 
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // 1. Explicit Dynamic & Multi-Tenant Sandbox Collections
    match /complaints-{id}/{document=**} { allow read, write: if true; }
    match /lost-and-found-{id}/{document=**} { allow read, write: if true; }
    match /restaurant-guests-{id}/{document=**} { allow read, write: if true; }
    match /hrms-{id}/{document=**} { allow read, write: if true; }
    match /cml-signin-{id}/{document=**} { allow read, write: if true; }
    match /cml-geofence-{id}/{document=**} { allow read, write: if true; }
    match /huddle-tasks-{id}/{document=**} { allow read, write: if true; }
    match /mailer-contacts-{id}/{document=**} { allow read, write: if true; }
    match /mailer-logs-{id}/{document=**} { allow read, write: if true; }
    match /flipbooks-{id}/{document=**} { allow read, write: if true; }
    match /newsletter-subscribers-{id}/{document=**} { allow read, write: if true; }
    match /rewards-config-{id}/{document=**} { allow read, write: if true; }
    match /forms-{id}/{document=**} { allow read, write: if true; }
    match /cml-forms-submissions-{id}/{document=**} { allow read, write: if true; }
    match /google-chat-messages-{id}/{document=**} { allow read, write: if true; }
    match /business-cards-{id}/{document=**} { allow read, write: if true; }

    match /daily-news/{document=**} { allow read, write: if true; }
    match /ramada_form_submissions/{document=**} { allow read, write: if true; }
    match /managed_cases/{document=**} { allow read, write: if true; }
    match /google_forms_links/{document=**} { allow read, write: if true; }
    match /it_tickets/{document=**} { allow read, write: if true; }
    match /lost-and-found/{document=**} { allow read, write: if true; }

    match /login_logs/{logId} {
      allow read, write: if true;
    }

    match /workflow-configs/{configId} {
      allow read, write: if true;
    }

    // 2. Business Cards (QR-codes)
    match /business-cards-cml/{documentId} {
      allow read, write: if true;
    }
    match /business-cards-ramada/{documentId} {
      allow read, write: if true;
    }
    match /business-cards-wyndham/{documentId} {
      allow read, write: if true;
    }

    // 3. User Profiles
    match /users/{userId} {
      allow read, write: if true;
    }

    // 4. Sandbox DB sync collection for stateless backend multi-container synchronization
    match /hybrid_sandbox/{document=**} {
      allow read, write: if true;
    }

    // 5. Forum Posts & Comments
    match /posts/{postId} {
      allow read, write: if true; 

      match /comments/{commentId} {
        allow read, write: if true;
      }
    }

    // 6. Notifications
    match /users/{userId}/notifications/{notificationId} {
      allow read, write: if true;
    }

    // 7. Global Safety Net
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
