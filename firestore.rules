rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Role helpers
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "digitalmedia@cml.com.fj" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["Administrator", "admin"])
      );
    }

    function isManager() {
      return isSignedIn() && (isAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Manager")
      );
    }

    function isAudit() {
      return isSignedIn() && (isAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Audit")
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'email', 'createdAt']) &&
             data.keys().size() <= 10 &&
             data.displayName is string && data.displayName.size() <= 128 &&
             data.email is string && data.email.size() <= 128 &&
             (!data.keys().contains('photoURL') || (data.photoURL is string && data.photoURL.size() <= 1000)) &&
             (!data.keys().contains('role') || data.role in ['Administrator', 'Manager', 'Audit', 'Staff', 'Viewer', 'admin', 'staff']) &&
             (!data.keys().contains('isPending') || data.isPending is bool);
    }

    function isValidUserCreate(data) {
      return isValidUser(data) && 
             data.createdAt == request.time &&
             (request.auth.token.email == "digitalmedia@cml.com.fj" || isAdmin() || !data.keys().contains('role') || data.role == 'Viewer'); 
    }

    function isValidUserUpdate(data) {
      return isValidUser(data) && data.createdAt == existing().createdAt;
    }

    function isValidPost(data) {
      return data.keys().hasAll(['title', 'content', 'authorId', 'authorName', 'createdAt']) &&
             data.keys().size() <= 10 &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 10000 &&
             data.authorId == request.auth.uid &&
             data.createdAt == request.time;
    }

    function isValidPostUpdate(data) {
      return data.keys().hasAll(['title', 'content', 'authorId', 'authorName', 'createdAt']) &&
             data.keys().size() <= 10 &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 10000 &&
             data.authorId == existing().authorId &&
             data.createdAt == existing().createdAt;
    }

    function isValidComment(data) {
      return data.keys().hasAll(['content', 'authorId', 'authorName', 'createdAt']) &&
             data.keys().size() <= 7 &&
             data.content is string && data.content.size() <= 2000 &&
             data.authorId == request.auth.uid &&
             data.createdAt == request.time;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['title', 'message', 'type', 'read', 'createdAt']) &&
             data.keys().size() <= 10 &&
             data.title is string && data.title.size() <= 200 &&
             data.message is string && data.message.size() <= 1000 &&
             data.type in ['forum', 'maintenance', 'system', 'role', 'lost-found'] &&
             data.read is bool &&
             data.createdAt == request.time;
    }

    function isValidComplaint(data) {
      return data.keys().hasAll(['guestName', 'roomNumber', 'type', 'priority', 'description', 'status', 'authorId', 'authorName', 'createdAt']) &&
             data.keys().size() <= 11 &&
             data.guestName is string && data.guestName.size() <= 200 &&
             data.roomNumber is string && data.roomNumber.size() <= 20 &&
             data.type in ["Folio Correction", "Key Sync Failure", "Profile Restoration", "Service Issue", "Restroom Issue", "Other"] &&
             data.priority in ["Low", "Medium", "High", "Urgent"] &&
             data.description is string && data.description.size() <= 2000 &&
             data.status in ["Pending", "In Progress", "Resolved"] &&
             (data.authorId == request.auth.uid || data.authorName == "System Seed") &&
             data.createdAt == request.time;
    }

    function isValidLostItem(data) {
      return data.keys().hasAll(['itemName', 'description', 'locationFound', 'staffName', 'status', 'authorId', 'createdAt']) &&
             data.keys().size() <= 12 &&
             data.itemName is string && data.itemName.size() <= 200 &&
             data.description is string && data.description.size() <= 2000 &&
             data.locationFound is string && data.locationFound.size() <= 200 &&
             data.staffName is string && data.staffName.size() <= 128 &&
             (!data.keys().contains('staffPosition') || (data.staffPosition is string && data.staffPosition.size() <= 128)) &&
             (!data.keys().contains('imageUrl') || (data.imageUrl is string && data.imageUrl.size() <= 1000000)) &&
             data.status in ["Found", "Claimed", "Disposed"] &&
             data.authorId == existing().authorId &&
             data.createdAt == existing().createdAt &&
             (!data.keys().contains('dispatchDetails') || (
               data.dispatchDetails.guestName is string &&
               data.dispatchDetails.dispatchedAt == request.time &&
               (!data.dispatchDetails.keys().contains('idDocumentUrl') || (data.dispatchDetails.idDocumentUrl is string && data.dispatchDetails.idDocumentUrl.size() <= 1000000)) &&
               (!data.dispatchDetails.keys().contains('recipientPhotoUrl') || (data.dispatchDetails.recipientPhotoUrl is string && data.dispatchDetails.recipientPhotoUrl.size() <= 1000000))
             ));
    }

    // 1. User Profiles
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin() || isManager() || isAudit();
      allow list: if isAdmin() || isManager() || isAudit(); 
      allow create: if (isOwner(userId) || isAdmin()) && isValidUserCreate(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && isValidUserUpdate(incoming());
      allow delete: if isAdmin();
    }

    // 2. Forum Posts
    match /posts/{postId} {
      allow read: if true; 
      allow create: if isSignedIn() && isValidId(postId) && isValidPost(incoming());
      allow update: if isSignedIn() && isOwner(existing().authorId) && 
                      isValidPostUpdate(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'category', 'updatedAt', 'authorPhotoURL', 'authorName']) &&
                      incoming().updatedAt == request.time;
      allow delete: if isSignedIn() && isOwner(existing().authorId);

      // 3. Comments (Sub-collection)
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && 
                        isValidId(commentId) && 
                        isValidComment(incoming()) &&
                        exists(/databases/$(database)/documents/posts/$(postId));
        allow delete: if isSignedIn() && isOwner(existing().authorId);
      }
    }

    // 4. Notifications
    match /users/{userId}/notifications/{notificationId} {
      allow list, get: if isOwner(userId);
      allow create: if isSignedIn() && isValidNotification(incoming());
      allow update: if isOwner(userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['read']) &&
                      incoming().read == true; 
      allow delete: if isOwner(userId);
    }

    // 5. Complaints
    match /complaints/{complaintId} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn() && isValidComplaint(incoming());
      allow update: if (isAdmin() || isManager() || isAudit()) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['status', 'priority']) &&
                      incoming().status in ["Pending", "In Progress", "Resolved"] &&
                      incoming().priority in ["Low", "Medium", "High", "Urgent"];
      allow delete: if isAdmin();
    }

    // 6. Lost & Found
    match /lost-and-found/{itemId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn() && 
                      incoming().authorId == request.auth.uid &&
                      incoming().createdAt == request.time &&
                      incoming().status == "Found";
      allow update: if (isAdmin() || isManager() || isAudit()) &&
                      isValidLostItem(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['status', 'imageUrl', 'itemName', 'description', 'locationFound', 'dispatchDetails']) &&
                      incoming().status in ["Found", "Claimed", "Disposed"];
      allow delete: if isAdmin();
    }
  }
}
